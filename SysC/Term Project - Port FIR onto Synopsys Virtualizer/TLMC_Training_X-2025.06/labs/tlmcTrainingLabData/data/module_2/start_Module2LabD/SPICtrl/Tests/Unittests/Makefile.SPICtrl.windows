!IFNDEF COWARE_CXX_COMPILER
COWARE_CXX_COMPILER=msvc-14.38-64
!ENDIF
!IFNDEF SNPS_VP_PRODUCT
SNPS_VP_PRODUCT=VAUTH
!ENDIF

TEST_DYNAMIC_LIBRARY_PATH=

# user defined extra compile and link options
EXTRA_CXXFLAGS =
EXTRA_LDFLAGS = 
OBJEXT=.$(COWARE_CXX_COMPILER).obj
# debug/optimize build flag
#NODEBUG=1
# for non verbose build output, use: V=@
V=

# source file list
ALL_OBJECTS = SPICtrlTest$(OBJEXT) 

# try to make the project independent from absolute path location
MODEL_BASEDIR = ./../..

# test executable name
TEST_CHECKER_BASE = SPICtrlTests.$(COWARE_CXX_COMPILER)
TEST_CHECKER = $(TEST_CHECKER_BASE).exe

# extra compiler options set by TLM Creator
TLMC_CXX_DEFINES    = 
TLMC_CXX_INCLUDES   = -I"$(SNPS_VP_HOME)/tlmcreator/templates/models/common/include" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_target_port/include" -I"$(SNPS_VP_HOME)/common/include" -I"$(SNPS_VP_HOME)/common/include/tlm" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_initiator_port/include" -I"$(SNPS_VP_HOME)/common/include/tlm_serial" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_can_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_lin_bus/SystemC/include" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_target_port/include/testing" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_initiator_port/include/testing" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/Testing/include" -I"$(SNPS_VP_HOME)/thirdparty_integrations/include" -I"$(MODEL_BASEDIR)" 
TLMC_CXX_FLAGS      = 

# extra link options set by TLM Creator
TLMC_LINK_FLAGS     = 
TLMC_LINK_PATHS     = -LIBPATH:"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/lib-$(COWARE_CXX_COMPILER)" 
TLMC_LINK_LIBRARIES = tlm_ft_spi_bus.lib 

!include $(SNPS_VP_HOME)/common/etc/build.preamble

# temoprary variables till they exist in the build.preamble files

CXX  = $(CXX)
cdebug = -Od -DDEBUG -Zi -FS
CXXFLAGS = -c $(cdebug) -D_CRT_SECURE_NO_WARNINGS $(CWR_SYSTEMC_CXXFLAGS) $(CWR_SYSTEMC_INCLUDE) -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/AMBA-PV/include -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/include $(TLMC_CXX_DEFINES) $(TLMC_CXX_INCLUDES) -I"../../SystemC/include" -I".." -I"."  $(CXXFLAGS) $(EXTRA_CXXFLAGS) $(TLMC_CXX_FLAGS)

LINK = $(LINKER)
LDFLAGS = -DEBUG $(SNPS_VP_SIM_LDFLAGS) $(TLMC_LINK_FLAGS) $(TLMC_LINK_PATHS) $(TLMC_LINK_LIBRARIES) scml2_testing.lib scml2_testing_systemc_main.lib

# optionally read in user defined makefile
USER_MAKEFILE = Makefile.SPICtrl.windows.user

!if exists ( $(USER_MAKEFILE) )
!include $(USER_MAKEFILE)
!endif


all: $(TEST_CHECKER) vpsession_sim.conf

run_test:
	$(V)set PATH=$(INNO_RUNTIME_PATH)$(TEST_DYNAMIC_LIBRARY_PATH)%%SNPS_VP_HOME%%\common\libso-$(COWARE_CXX_COMPILER);%%PATH%%
	$(V)set COWARE_CXX_COMPILER=$(COWARE_CXX_COMPILER)
	$(V)set SNPS_VP_PRODUCT=$(SNPS_VP_PRODUCT)
	-@rmdir /s /q functional_coverage 2> NUL
	$(V)vpsession $(TEST_CHECKER) --cwr_monitors vpconfigs/SPICtrl/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || ($(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/ && EXIT /B 1)
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

check: $(TEST_CHECKER)
	$(V)set PATH=$(INNO_RUNTIME_PATH)$(TEST_DYNAMIC_LIBRARY_PATH)%%SNPS_VP_HOME%%\common\libso-$(COWARE_CXX_COMPILER);%%PATH%%
	$(V)set COWARE_CXX_COMPILER=$(COWARE_CXX_COMPILER)
	$(V)set SNPS_VP_PRODUCT=$(SNPS_VP_PRODUCT)
	-@rmdir /s /q functional_coverage 2> NUL
	$(V)vpsession $(TEST_CHECKER) --cwr_nosession --cwr_monitors vpconfigs/SPICtrl/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || ($(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/ && EXIT /B 1)
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

clean:
	$(V)del $(TEST_CHECKER) $(TEST_CHECKER).manifest $(TEST_CHECKER_BASE).lib $(TEST_CHECKER_BASE).ilk $(TEST_CHECKER_BASE).exp $(ALL_OBJECTS) vpsession_sim.conf *.pdb functional_coverage.* monitors.xml snps.vpproject
	-@rmdir /s /q functional_coverage 2> NUL
	-@rmdir /s /q analysis_results 2> NUL
	-@rmdir /s /q vpconfigs 2> NUL

$(TEST_CHECKER): $(ALL_OBJECTS)
	$(V)$(LINK) -out:$@  $(ALL_OBJECTS) $(LDFLAGS)

vpsession_sim.conf:
	(echo LOAD_LIB_DIR $(SNPS_VP_HOME)commonlibso-$(COWARE_CXX_COMPILER) && echo RELEASE W-2025.03) > $@

# build target for model code
SPICtrl$(OBJEXT): ../../SystemC/src/SPICtrl.cc ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h
	$(V) $(CXX) -Fo$@ $(CXXFLAGS) ../../SystemC/src/SPICtrl.cc

# build target for model code
SPICtrlBase$(OBJEXT): ../../SystemC/src/SPICtrlBase.cc ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h
	$(V) $(CXX) -Fo$@ $(CXXFLAGS) ../../SystemC/src/SPICtrlBase.cc


# build targets for user defined sources
TX_PATH$(OBJEXT):  $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc ../SPICtrlMirrorBase.h ../SPICtrlMirror.h ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc
	$(V) $(CXX) -Fo$@ $(CXXFLAGS) $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc

RX_PATH$(OBJEXT):  $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc ../SPICtrlMirrorBase.h ../SPICtrlMirror.h ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc
	$(V) $(CXX) -Fo$@ $(CXXFLAGS) $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc



# build target for test harness executable
SPICtrlTest$(OBJEXT): SPICtrlTest.cc SPICtrlTestHarness.h ../SPICtrlMirrorBase.h ../SPICtrlMirror.h ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc
	$(V) $(CXX) -Fo$@ $(CXXFLAGS) SPICtrlTest.cc


# helper target to launch test harness with VisualStudio IDE
devenv: $(TEST_CHECKER)
	@echo.
	@echo "Launching MS Visual Studio with test harness solution file for $(COWARE_CXX_COMPILER) compiler..."
	@echo.
	$(V)set PATH=%%SNPS_VP_HOME%%\common\libso-$(COWARE_CXX_COMPILER);%%PATH%%
	$(V)set COWARE_CXX_COMPILER=$(COWARE_CXX_COMPILER)
	$(V)set SNPS_VP_PRODUCT=$(SNPS_VP_PRODUCT)
!IF "$(COWARE_CXX_COMPILER)" == "msvc-14.34-64"
	$(V)devenv SPICtrlTests.vc1434.sln
!ELSEIF "$(COWARE_CXX_COMPILER)" == "msvc-14.38-64"
	$(V)devenv SPICtrlTests.vc1438.sln
!ENDIF

# launch test harness with VP Explorer
debug: $(TEST_CHECKER) vpsession_sim.conf
	@echo.
	@echo "Launching  test harness with VP Explorer..."
	@echo.
	$(V)vpexplorer -c vpconfigs/SPICtrl/SPICtrl.vpcfg

help:
	@echo.
	@echo "Usage:"
	@echo.
	@echo "   nmake -f makefile [options]   build and start model test harness"
	@echo.
	@echo "Options:"
	@echo.
	@echo "   (no arguments)                rebuild model test harness executable,"
	@echo "                                   same as 'all'"
	@echo "   all                           rebuild model test harness executable"
	@echo "   clean                         clean all derived files"
	@echo "   check                         build and run test harness"
	@echo "   devenv                        build test harness and launch MS Visual Studio"
	@echo "                                   with test harness solution file"
	@echo "   debug                         build test harness and launch test harness with VP Explorer"
	@echo "   help                          print this help information"
	@echo.

