# extended list of supported C++ file extensions
.SUFFIXES:  .cc

# configuration defaults
ifndef COWARE_CXX_COMPILER
COWARE_CXX_COMPILER:=gcc-12.3-64
endif
ifndef SNPS_VP_PRODUCT
SNPS_VP_PRODUCT=VAUTH
endif

TEST_DYNAMIC_LIBRARY_PATH=

# coverage specific compile and link options
ifndef ENABLE_COVERAGE
COVERAGE_FLAGS =
GCOV    =
LCOV    = 
GENHTML =
else
COVERAGE_FLAGS = -fprofile-arcs -ftest-coverage 
GCOV    = $(SNPS_VP_HOME)/gnu/$(COWARE_CXX_COMPILER)/bin/gcov
LCOV    = lcov
GENHTML = genhtml
endif

# user defined extra compile and link options
EXTRA_CXXFLAGS =
EXTRA_LDFLAGS = 
OBJEXT=.$(COWARE_CXX_COMPILER).o
VPATH=../../SystemC/src:.
# debug/optimize build flag
#NODEBUG=1
# for non verbose build output, use: V=@
V=

# source file list
ALL_OBJECTS = SPICtrlTest$(OBJEXT) 

# try to make the project independent from absolute path location
MODEL_BASEDIR = ./../..

# test executable name
TEST_CHECKER = SPICtrlTests.$(COWARE_CXX_COMPILER)

# extra compiler options set by TLM Creator
TLMC_CXX_DEFINES    = 
TLMC_CXX_INCLUDES   = -I"$(SNPS_VP_HOME)/tlmcreator/templates/models/common/include" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_target_port/include" -I"$(SNPS_VP_HOME)/common/include" -I"$(SNPS_VP_HOME)/common/include/tlm" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_initiator_port/include" -I"$(SNPS_VP_HOME)/common/include/tlm_serial" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_can_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_lin_bus/SystemC/include" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_target_port/include/testing" -I"$(SNPS_VP_HOME)/common/include/scml2_protocol_engines/tlm2_ft_initiator_port/include/testing" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/Testing/include" -I"$(SNPS_VP_HOME)/thirdparty_integrations/include" -I"$(MODEL_BASEDIR)" 
TLMC_CXX_FLAGS      = 

# extra link options set by TLM Creator
TLMC_LINK_FLAGS     = 
TLMC_LINK_OPTIONS   = -Wl,-rpath=.:$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/lib-$(COWARE_CXX_COMPILER)  -L$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/lib-$(COWARE_CXX_COMPILER) -ltlm_ft_spi_bus

include $(SNPS_VP_HOME)/common/etc/build.preamble

# optionally read in user defined makefile
USER_MAKEFILE = Makefile.SPICtrl.linux.user

-include $(USER_MAKEFILE)

CXXFLAGS += $(CWR_SYSTEMC_INCLUDE) $(CWR_SYSTEMC_CXXFLAGS) -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/AMBA-PV/include -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/include -Wall -g -O0 $(TLMC_CXX_DEFINES) $(TLMC_CXX_INCLUDES) -I"../../SystemC/include" -I".." -I"."  $(COVERAGE_FLAGS) $(EXTRA_CXXFLAGS) $(TLMC_CXX_FLAGS)
LDFLAGS += -Wl,--start-group $(TLMC_LINK_FLAGS) $(TLMC_LINK_OPTIONS) $(TLMC_LINK_LIBRARIES) -lscml2_testing_systemc_main -lscml2_testing $(CWR_SCO2_LDFLAGS) $(COVERAGE_FLAGS) $(EXTRA_LDFLAGS) -Wl,--end-group

ifneq ($(shell uname -m),aarch64)
LDFLAGS += -m64
endif

.PHONY: all
all: $(TEST_CHECKER)

export ORBendPoint=
export LD_LIBRARY_PATH:=$(INNO_RUNTIME_PATH)$(TEST_DYNAMIC_LIBRARY_PATH)$(SNPS_VP_HOME)/common/libso-$(COWARE_CXX_COMPILER):$(SNPS_VP_HOME)/gnu/$(COWARE_CXX_COMPILER)/lib64:$(LD_LIBRARY_PATH)

.PHONY: run_test
run_test:
	$(V)rm -rf functional_coverage/
	$(V)vpsession ./$(TEST_CHECKER) --cwr_monitors vpconfigs/SPICtrl/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || { $(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/; /bin/false; }
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

.PHONY: check
check: $(TEST_CHECKER)
	$(V)rm -rf functional_coverage/
	$(V)vpsession ./$(TEST_CHECKER) --cwr_monitors vpconfigs/SPICtrl/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || { $(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/; /bin/false; }
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

ifneq ($(COVERAGE_FLAGS),)
ifneq ($(shell which $(LCOV)),)
ifneq ($(shell which $(GENHTML)),)
coverage: check
	@rm -rf coverage_report.txt SPICtrl_coverage *.info	
	@$(GCOV) -s `readlink -m $(CURDIR)/../../` -r ../../SystemC/libso-$(COWARE_CXX_COMPILER)/FastBuild/*/*/src/SPICtrl.o | grep -A3 "File '.." > coverage_report.txt
	@$(LCOV) --gcov-tool $(GCOV) -o SPICtrl.info -c -d ../../SystemC/src -d ../../SystemC/libso-$(COWARE_CXX_COMPILER)/FastBuild/*/*/src/ -d ../../SystemC/include -d .. -d . --no-external >lcov.log
	@$(LCOV) -r SPICtrl.info '*Covermodel*' '*dladapter.cc' -o SPICtrl_nocovermodel.info >>lcov.log
	@$(GENHTML) --demangle-cpp -o SPICtrl_coverage SPICtrl_nocovermodel.info
	@echo ""
	@echo "Info: Model coverage output report generated in SPICtrl_coverage"
	@echo "      launch your browser on SPICtrl_coverage/index.html"
	@echo ""
else
coverage:
	@echo  "Please put '$(GENHTML)' into your path"
endif
else
coverage:
	@echo  "Please put '$(LCOV)' into your path"
endif
else
coverage:
	@echo  "Please add 'ENABLE_COVERAGE=true' to the command options"
endif

.PHONY: clean
clean:
	$(V)rm -rf $(TEST_CHECKER) $(ALL_OBJECTS) functional_coverage/ analysis_results/ vpconfigs/
	$(V)rm -rf coverage_report.txt SPICtrl_coverage *.info *.gcov *.gcno *.gcda lcov.log functional_coverage.* monitors.xml snps.vpproject

$(TEST_CHECKER): $(ALL_OBJECTS)
	$(V)export COWARE_CXX_COMPILER=$(COWARE_CXX_COMPILER)
	$(V)export SNPS_VP_PRODUCT=$(SNPS_VP_PRODUCT)
	$(V)$(SNPS_VP_PURIFY) $(CXX) -o $@ $(ALL_OBJECTS) $(LDFLAGS)
	
# build target for test harness executable
SPICtrlTest$(OBJEXT): SPICtrlTestHarness.h ../SPICtrlMirrorBase.h ../SPICtrlMirror.h ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h

# build target for model code
SPICtrl$(OBJEXT): ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h


# build targets for user defined sources
TX_PATH$(OBJEXT): $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc ../SPICtrlMirrorBase.h ../SPICtrlMirror.h  ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h
	$(V) $(CXX) -c -o $@ $(CXXFLAGS) $(MODEL_BASEDIR)/SystemC/src/TX_PATH.cc

RX_PATH$(OBJEXT): $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc ../SPICtrlMirrorBase.h ../SPICtrlMirror.h  ../../SystemC/include/SPICtrlBase.h ../../SystemC/include/SPICtrl.h ../../SystemC/include/SPICtrlCovermodelBase.h ../../SystemC/include/SPICtrlCovermodel.h
	$(V) $(CXX) -c -o $@ $(CXXFLAGS) $(MODEL_BASEDIR)/SystemC/src/RX_PATH.cc


%$(OBJEXT): %.cc
	$(V)$(CC) $(CXXFLAGS) -o $@ -c $<


# launch test harness with VP Explorer
debug: $(TEST_CHECKER)
	@echo ""
	@echo "Launching  test harness with VP Explorer..."
	@echo ""
	$(V)vpexplorer -c vpconfigs/SPICtrl/SPICtrl.vpcfg

# print usage
help:
	@echo
	@echo "Usage:"
	@echo
	@echo "   nmake -f makefile [options]   build and start model test harness"
	@echo
	@echo "Options:"
	@echo
	@echo "   (no arguments)                rebuild model test harness executable,"
	@echo "                                   same as 'all'"
	@echo "   all                           rebuild model test harness executable"
	@echo "   clean                         clean all derived files"
	@echo "   check                         build and run test harness"
	@echo "   debug                         build test harness and launch test harness with VP Explorer"
	@echo "   help                          print this help information"
	@echo

