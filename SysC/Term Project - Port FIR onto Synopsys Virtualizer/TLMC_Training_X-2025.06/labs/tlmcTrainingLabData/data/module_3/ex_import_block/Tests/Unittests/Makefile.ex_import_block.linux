.SUFFIXES:  .cc

# configuration defaults
ifndef COWARE_CXX_COMPILER
COWARE_CXX_COMPILER:=gcc-12.3-64
endif
ifndef SNPS_VP_PRODUCT
SNPS_VP_PRODUCT=VAUTH
endif

TEST_DYNAMIC_LIBRARY_PATH=

# coverage specific compile and link options
ifndef ENABLE_COVERAGE
COVERAGE_FLAGS =
GCOV    =
LCOV    = 
GENHTML =
else
COVERAGE_FLAGS = -fprofile-arcs -ftest-coverage 
GCOV    = $(SNPS_VP_HOME)/gnu/$(COWARE_CXX_COMPILER)/bin/gcov
LCOV    = lcov
GENHTML = genhtml
endif

# user defined extra compile and link options
EXTRA_CXXFLAGS =
EXTRA_LDFLAGS = 
OBJEXT=.$(COWARE_CXX_COMPILER).o
VPATH=../../SystemC/src:.
# debug/optimize build flag
#NODEBUG=1
# for non verbose build output, use: V=@
V=

# source file list
ALL_OBJECTS = ex_import_blockTest$(OBJEXT) 

# try to make the project independent from absolute path location
MODEL_BASEDIR = ./../..

# test executable name
TEST_CHECKER = ex_import_blockTests.$(COWARE_CXX_COMPILER)

# extra compiler options set by TLM Creator
TLMC_CXX_DEFINES    = 
TLMC_CXX_INCLUDES   = -I"$(SNPS_VP_HOME)/tlmcreator/templates/models/common/include" -I"$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/AMBA-PV/include" -I"$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/include" -I"$(SNPS_VP_HOME)/common/include/tlm_serial" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_can_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_spi_bus/SystemC/include" -I"$(SNPS_VP_HOME)/../../IP/tlm_ft_lin_bus/SystemC/include" -I"$(MODEL_BASEDIR)" 
TLMC_CXX_FLAGS      = 

# extra link options set by TLM Creator
TLMC_LINK_FLAGS     = 
TLMC_LINK_OPTIONS   = 

include $(SNPS_VP_HOME)/common/etc/build.preamble

# optionally read in user defined makefile
USER_MAKEFILE = Makefile.ex_import_block.linux.user

-include $(USER_MAKEFILE)

CXXFLAGS += $(CWR_SYSTEMC_INCLUDE) $(CWR_SYSTEMC_CXXFLAGS) -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/AMBA-PV/include -I$(SNPS_VP_HOME)/IP_common/AMBA_TLM2_BL/include -Wall -g -O0 $(TLMC_CXX_DEFINES) $(TLMC_CXX_INCLUDES) -I"../../SystemC/include" -I".." -I"."  $(COVERAGE_FLAGS) $(EXTRA_CXXFLAGS) $(TLMC_CXX_FLAGS)
LDFLAGS += -Wl,--start-group $(TLMC_LINK_FLAGS) $(TLMC_LINK_OPTIONS) $(TLMC_LINK_LIBRARIES) -lscml2_testing_systemc_main -lscml2_testing $(CWR_SCO2_LDFLAGS) $(COVERAGE_FLAGS) $(EXTRA_LDFLAGS) -Wl,--end-group

ifneq ($(shell uname -m),aarch64)
LDFLAGS += -m64
endif

.PHONY: all
all: $(TEST_CHECKER)

export ORBendPoint=
export LD_LIBRARY_PATH:=$(INNO_RUNTIME_PATH)$(TEST_DYNAMIC_LIBRARY_PATH)$(SNPS_VP_HOME)/common/libso-$(COWARE_CXX_COMPILER):$(SNPS_VP_HOME)/gnu/$(COWARE_CXX_COMPILER)/lib64:$(LD_LIBRARY_PATH)

.PHONY: run_test
run_test:
	$(V)rm -rf functional_coverage/
	$(V)vpsession ./$(TEST_CHECKER) --cwr_monitors vpconfigs/ex_import_block/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || { $(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/; /bin/false; }
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

.PHONY: check
check: $(TEST_CHECKER)
	$(V)rm -rf functional_coverage/
	$(V)vpsession ./$(TEST_CHECKER) --cwr_monitors vpconfigs/ex_import_block/Default.monitors $(TLMC_EXTRA_TEST_ARGS) || { $(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/; /bin/false; }
	$(V)functional_coverage_report_generator functional_coverage.html $(DATA_OUTPUT_FOLDER)functional_coverage/

ifneq ($(COVERAGE_FLAGS),)
ifneq ($(shell which $(LCOV)),)
ifneq ($(shell which $(GENHTML)),)
coverage: check
	@rm -rf coverage_report.txt ex_import_block_coverage *.info	
	@$(GCOV) -s `readlink -m $(CURDIR)/../../` -r ../../SystemC/libso-$(COWARE_CXX_COMPILER)/FastBuild/*/*/src/ex_import_block.o | grep -A3 "File '.." > coverage_report.txt
	@$(LCOV) --gcov-tool $(GCOV) -o ex_import_block.info -c -d ../../SystemC/src -d ../../SystemC/libso-$(COWARE_CXX_COMPILER)/FastBuild/*/*/src/ -d ../../SystemC/include -d .. -d . --no-external >lcov.log
	@$(LCOV) -r ex_import_block.info '*Covermodel*' '*dladapter.cc' -o ex_import_block_nocovermodel.info >>lcov.log
	@$(GENHTML) --demangle-cpp -o ex_import_block_coverage ex_import_block_nocovermodel.info
	@echo ""
	@echo "Info: Model coverage output report generated in ex_import_block_coverage"
	@echo "      launch your browser on ex_import_block_coverage/index.html"
	@echo ""
else
coverage:
	@echo  "Please put '$(GENHTML)' into your path"
endif
else
coverage:
	@echo  "Please put '$(LCOV)' into your path"
endif
else
coverage:
	@echo  "Please add 'ENABLE_COVERAGE=true' to the command options"
endif

.PHONY: clean
clean:
	$(V)rm -rf $(TEST_CHECKER) $(ALL_OBJECTS) functional_coverage/ analysis_results/ vpconfigs/
	$(V)rm -rf coverage_report.txt ex_import_block_coverage *.info *.gcov *.gcno *.gcda lcov.log functional_coverage.* monitors.xml snps.vpproject

$(TEST_CHECKER): $(ALL_OBJECTS)
	$(V)export COWARE_CXX_COMPILER=$(COWARE_CXX_COMPILER)
	$(V)export SNPS_VP_PRODUCT=$(SNPS_VP_PRODUCT)
	$(V)$(SNPS_VP_PURIFY) $(CXX) -o $@ $(ALL_OBJECTS) $(LDFLAGS)
	
# build target for test harness executable
ex_import_blockTest$(OBJEXT): ex_import_blockTestHarness.h ../ex_import_blockMirrorBase.h ../ex_import_blockMirror.h  /home/user1/sc25/sc2568/TLMCreation_Quickstart_Training_X-2025.06/TLMC_Training_X-2025.06/labs/tlmcTrainingLabData/tlmcTrainingLabData/data/module_3/ImportSystemC/include/block.h

# build target for model code
ex_import_block$(OBJEXT):  /home/user1/sc25/sc2568/TLMCreation_Quickstart_Training_X-2025.06/TLMC_Training_X-2025.06/labs/tlmcTrainingLabData/tlmcTrainingLabData/data/module_3/ImportSystemC/include/block.h


# build targets for user defined sources

%$(OBJEXT): %.cc
	$(V)$(CC) $(CXXFLAGS) -o $@ -c $<


# launch test harness with VP Explorer
debug: $(TEST_CHECKER)
	@echo ""
	@echo "Launching  test harness with VP Explorer..."
	@echo ""
	$(V)vpexplorer -c vpconfigs/ex_import_block/ex_import_block.vpcfg

# print usage
help:
	@echo
	@echo "Usage:"
	@echo
	@echo "   nmake -f makefile [options]   build and start model test harness"
	@echo
	@echo "Options:"
	@echo
	@echo "   (no arguments)                rebuild model test harness executable,"
	@echo "                                   same as 'all'"
	@echo "   all                           rebuild model test harness executable"
	@echo "   clean                         clean all derived files"
	@echo "   check                         build and run test harness"
	@echo "   debug                         build test harness and launch test harness with VP Explorer"
	@echo "   help                          print this help information"
	@echo

